# Discord OAuth2 Credentials
# Získejte na https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# NextAuth Configuration
# Vygenerujte silný tajný klíč přes `openssl rand -base64 32`
AUTH_SECRET=your_auth_secret_key
# NextAuth v5 v Next.js automaticky používá NEXTAUTH_URL pro interní účely, doporučeno nastavit:
NEXTAUTH_URL=http://localhost:3000

# Airtable REST API Configuration
# Získejte svůj osobní přístupový token (Personal Access Token) na https://airtable.com/create/tokens
AIRTABLE_API_KEY=pat_your_airtable_personal_access_token
# ID vaší Airtable Base (naleznete v URL adresy vaší Airtable báze, např. appXXXXXXXXX)
AIRTABLE_BASE_ID=app_your_airtable_base_id

# Webhook Security
# Libovolný silný tajný řetězec, který vložíte do Make.com webhooku pro zabezpečení odesílání karet
WEBHOOK_SECRET=your_custom_webhook_secret_key
